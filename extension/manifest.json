{
  "manifest_version": 3,
  "name": "Guy Tab-ieri",
  "version": "1.0.0",
  "description": "Close all tabs on the same host",
  "permissions": ["tabs"],
  "icons": {
    "128": "icon.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "mac": "Command+Alt+T",
        "default": "Ctrl+Alt+T"
      },
      "description": "Open Guy Tab-ieri"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Guy Tab-ieri",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{3c084cc6-051b-4a77-8ea3-573eb532f4f0}",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
